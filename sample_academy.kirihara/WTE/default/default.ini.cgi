[default]
;---------------------------------------------------------------------
;■システム名称
;---------------------------------------------------------------------
product_name = WTE

;---------------------------------------------------------------------
;■本システムのホストのURL
;最後にスラッシュを入れないで下さい。
;---------------------------------------------------------------------
ssl_host_url = https://academy.kirihara.co.jp
www_host_url = http://academy.kirihara.co.jp

;---------------------------------------------------------------------
;■staticディレクトリのURL
;最後にスラッシュを入れないで下さい。
;---------------------------------------------------------------------
static_url = /WTE/static

;---------------------------------------------------------------------
;■ログオンセッション有効期間
;管理メニューへの最後のアクセスから、ここで指定した時間を経過するとロ
;グオフした状態となります。
;1～999時間の間で指定してください。少数を指定することはできません。
;---------------------------------------------------------------------
session_expire = 1

;---------------------------------------------------------------------
;■SMTPポート番号
;---------------------------------------------------------------------
smtp_port = 25

;---------------------------------------------------------------------
;■SMTPタイムアウト（秒）
;---------------------------------------------------------------------
smtp_timeout = 30

;---------------------------------------------------------------------
;■MySQL
;---------------------------------------------------------------------
db_host = localhost
db_name = wte
db_user = wte
db_pass = SdC~ZkCG_n
db_port = 3306

;---------------------------------------------------------------------
;■Memcached
;---------------------------------------------------------------------
memcached_servers1 = localhost:11211

;---------------------------------------------------------------------
;■会員登録セッションデータ有効期間（秒）
;---------------------------------------------------------------------
reg_session_expire = 3600

;---------------------------------------------------------------------
;■会員パスワード・リセット・セッションデータ有効期間（秒）
;---------------------------------------------------------------------
pwdrst_session_expire = 3600
;---------------------------------------------------------------------
;■会員パスワード・リセット 暗号化秘密鍵文字列
;---------------------------------------------------------------------
pwdrst_secret_key = 66sbvrz5has5dnrxutnm

;---------------------------------------------------------------------
;■マイページセッションデータ有効期間（時間）
;---------------------------------------------------------------------
mypage_session_expire = 6

;---------------------------------------------------------------------
;■マイページ自動ログインセッションデータ有効期間（時間）
;---------------------------------------------------------------------
mypage_auto_login_session_expire = 720

;---------------------------------------------------------------------
;■代理店メニューセッションデータ有効期間（時間）
;---------------------------------------------------------------------
selmnu_session_expire = 6

;---------------------------------------------------------------------
;■代理店メニュー自動ログインセッションデータ有効期間（時間）
;---------------------------------------------------------------------
selmnu_auto_login_session_expire = 720


;---------------------------------------------------------------------
;■講師メニューセッションデータ有効期間（時間）
;---------------------------------------------------------------------
prfmnu_session_expire = 6

;---------------------------------------------------------------------
;■講師メニュー自動ログインセッションデータ有効期間（時間）
;---------------------------------------------------------------------
prfmnu_auto_login_session_expire = 720

;---------------------------------------------------------------------
;■Memcacheキャッシュデータ有効期間（秒）
;---------------------------------------------------------------------
cache_expire = 300

;---------------------------------------------------------------------
;■消費税率（パーセント）
;  消費税率を変更する場合は、memcachedを必ず再起動してください。
;---------------------------------------------------------------------
tax_rate = 10


;---------------------------------------------------------------------
;■会員ロゴ
;---------------------------------------------------------------------
;・格納ディレクトリパスとURL（最後にスラッシュを入れないこと）
;---------------------------------------------------------------------
member_logo_dir = /var/www/html/WTE/imgs/member
member_logo_dir_url = /WTE/imgs/member
;---------------------------------------------------------------------
;・アップロードされるロゴ画像ファイルの最大サイズ(MB)
;---------------------------------------------------------------------
member_logo_max_size = 10
;---------------------------------------------------------------------
;・サムネイルの縦横サイズ(ピクセル)
;---------------------------------------------------------------------
;（小）
member_logo_1_w = 100
member_logo_1_h = 100
;（中）
member_logo_2_w = 200
member_logo_2_h = 200
;（大）
member_logo_3_w = 400
member_logo_3_h = 400
;---------------------------------------------------------------------
;・ロゴ画像フォーマット（ファイル拡張子となる gif, jpg, png のいずれか）
;---------------------------------------------------------------------
member_logo_ext = jpg


;---------------------------------------------------------------------
;■講師ロゴ
;---------------------------------------------------------------------
;・格納ディレクトリパスとURL（最後にスラッシュを入れないこと）
;  この中に、ロゴ登録時のテンポラリーディレクトリが生成される。
;---------------------------------------------------------------------
prof_logo_dir = /var/www/html/WTE/imgs/prof
prof_logo_dir_url = /WTE/imgs/prof
;---------------------------------------------------------------------
;・アップロードされるロゴ画像ファイルの最大サイズ(MB)
;---------------------------------------------------------------------
prof_logo_max_size = 10
;---------------------------------------------------------------------
;・サムネイルの縦横サイズ(ピクセル)
;---------------------------------------------------------------------
;（小）
prof_logo_1_w = 100
prof_logo_1_h = 100
;（中）
prof_logo_2_w = 200
prof_logo_2_h = 200
;（大）
prof_logo_3_w = 400
prof_logo_3_h = 400
;---------------------------------------------------------------------
;・ロゴ画像フォーマット（ファイル拡張子となる gif, jpg, png のいずれか）
;---------------------------------------------------------------------
prof_logo_ext = jpg



;---------------------------------------------------------------------
;■授業ロゴ
;---------------------------------------------------------------------
;・格納ディレクトリパスとURL（最後にスラッシュを入れないこと）
;  この中に、ロゴ登録時のテンポラリーディレクトリが生成される。
;---------------------------------------------------------------------
course_logo_dir = /var/www/html/WTE/imgs/course
course_logo_dir_url = /WTE/imgs/course
;---------------------------------------------------------------------
;・アップロードされるロゴ画像ファイルの最大サイズ(MB)
;---------------------------------------------------------------------
course_logo_max_size = 10
;---------------------------------------------------------------------
;・サムネイルの縦横サイズ(ピクセル)
;---------------------------------------------------------------------
;（小）
course_logo_1_w = 100
course_logo_1_h = 100
;（中）
course_logo_2_w = 200
course_logo_2_h = 200
;（大）
course_logo_3_w = 400
course_logo_3_h = 400
;---------------------------------------------------------------------
;・ロゴ画像フォーマット（ファイル拡張子となる gif, jpg, png のいずれか）
;---------------------------------------------------------------------
course_logo_ext = jpg


;---------------------------------------------------------------------
;■ダウンロード商品ロゴ
;---------------------------------------------------------------------
;・格納ディレクトリパスとURL（最後にスラッシュを入れないこと）
;---------------------------------------------------------------------
dwn_logo_dir = /var/www/html/WTE/imgs/dwn
dwn_logo_dir_url = /WTE/imgs/dwn
;---------------------------------------------------------------------
;・アップロードされるロゴ画像ファイルの最大サイズ(MB)
;---------------------------------------------------------------------
dwn_logo_max_size = 10
;---------------------------------------------------------------------
;・サムネイルの縦横サイズ(ピクセル)
;---------------------------------------------------------------------
;（小）
dwn_logo_1_w = 100
dwn_logo_1_h = 100
;（中）
dwn_logo_2_w = 200
dwn_logo_2_h = 200
;（大）
dwn_logo_3_w = 400
dwn_logo_3_h = 400
;---------------------------------------------------------------------
;・ロゴ画像フォーマット（ファイル拡張子となる gif, jpg, png のいずれか）
;---------------------------------------------------------------------
dwn_logo_ext = jpg


;---------------------------------------------------------------------
;■ダウンロード商品ファイル格納ディレクトリ
;・最後にスラッシュを入れないこと
;・ドキュメント・ルート外のパスを指定すること
;---------------------------------------------------------------------
dwn_file_dir = /var/www/WTE/data/dwn


;---------------------------------------------------------------------
;■ダイレクトメッセージ添付ファイル格納ディレクトリ
;・最後にスラッシュを入れないこと
;・ドキュメント・ルート外のパスを指定すること
;---------------------------------------------------------------------
dmsg_file_dir = /var/www/WTE/data/dmsg

;---------------------------------------------------------------------
;■ダイレクトメッセージ添付ファイルの有効期限（日）
;---------------------------------------------------------------------
dmsg_file_expire_days = 14

;---------------------------------------------------------------------
;■会員の「目的」の選択項目数（最大32個まで）
;---------------------------------------------------------------------
member_purpose_num = 32

;---------------------------------------------------------------------
;■会員の「希望」の選択項目数（最大32個まで）
;---------------------------------------------------------------------
member_demand_num = 32

;---------------------------------------------------------------------
;■会員の「興味」の選択項目数（最大32個まで）
;---------------------------------------------------------------------
member_interest_num = 32

;---------------------------------------------------------------------
;■会員の「レベル・属性」の選択項目数（最大32個まで）
