member_fav_limit = 100

;---------------------------------------------------------------------
;■講師の「特徴」の選択項目数（最大32個まで）
;---------------------------------------------------------------------
prof_character_num = 32

;---------------------------------------------------------------------
;■講師の「興味」の選択項目数（最大32個まで）
;---------------------------------------------------------------------
prof_interest_num = 32

;---------------------------------------------------------------------
;■講師の「ランク」の定義項目数
;---------------------------------------------------------------------
prof_rank_num = 5

